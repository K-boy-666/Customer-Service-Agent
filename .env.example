# Runtime
APP_ENV=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite+pysqlite:///data/orders.db
# Production example:
# DATABASE_URL=mysql+pymysql://customer_service:change-me@mysql:3306/customer_service?charset=utf8mb4

# Auth / OIDC
OIDC_ISSUER=customer-service-dev
OIDC_AUDIENCE=customer-service-api
OIDC_JWKS_URL=
OIDC_ALGORITHMS=RS256
# Development only. Do not set this to the default in production.
AUTH_DEV_SECRET=customer-service-dev-secret-min-32-bytes

# OTP
OTP_PROVIDER=dev
OTP_TTL_MINUTES=10

# API / MCP clients
API_BASE_URL=http://localhost:8000
API_KEY=
IDENTITY_VERIFICATION=

# Analytics
REPORT_TIMEZONE=Asia/Shanghai

# FAQ retrieval
FAQ_RAG_BACKEND=auto
FAQ_RAG_MODEL=shibing624/text2vec-base-chinese
FAQ_RAG_LOCAL_FILES_ONLY=1
