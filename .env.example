# Runtime
APP_ENV=development
LOG_LEVEL=INFO
# Leave empty for auto (production=JSON, development=colored). Set to true/false to override.
LOG_JSON=

# Database
DATABASE_URL=sqlite+pysqlite:///data/orders.db
# Production example:
# DATABASE_URL=mysql+pymysql://customer_service:change-me@mysql:3306/customer_service?charset=utf8mb4
# Alternatively, set DB_PASSWORD_FILE to read the password from a Docker secret file:
# DB_PASSWORD_FILE=/run/secrets/mysql_password

# MySQL connection pool (ignored for SQLite)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30

# Auth / OIDC
OIDC_ISSUER=customer-service-dev
OIDC_AUDIENCE=customer-service-api
OIDC_JWKS_URL=
OIDC_ALGORITHMS=RS256
# Development only. Do not set this to the default in production.
# Supports _FILE suffix for Docker secrets: AUTH_DEV_SECRET_FILE=/run/secrets/auth_dev_secret
AUTH_DEV_SECRET=customer-service-dev-secret-min-32-bytes

# OTP
OTP_PROVIDER=dev
OTP_TTL_MINUTES=10

# API / MCP clients
API_BASE_URL=http://localhost:8000
API_KEY=
IDENTITY_VERIFICATION=

# Analytics
REPORT_TIMEZONE=Asia/Shanghai

# FAQ retrieval
FAQ_RAG_BACKEND=auto
FAQ_RAG_MODEL=shibing624/text2vec-base-chinese
FAQ_RAG_LOCAL_FILES_ONLY=1

# Monitoring (Grafana)
GRAFANA_ADMIN_PASSWORD=admin

# Prometheus multi-process mode (required when using uvicorn --workers N or gunicorn)
# Set to a directory path that exists and is empty before startup.
# PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_metrics

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URI=memory://
# Production example: RATE_LIMIT_STORAGE_URI=redis://redis:6379/1
RATE_LIMIT_OTP=5/minute
RATE_LIMIT_ORCHESTRATOR=60/minute
RATE_LIMIT_WRITE=30/minute
RATE_LIMIT_READ=120/minute
